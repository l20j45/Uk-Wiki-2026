---
interface Props { title: string; }
const { title } = Astro.props;
import PanicButton from '../components/PanicButton.jsx';
import "../styles/global.css";
---
<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/icon.svg" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="global.css">
    <title>{title}</title>
  </head>
  <body class="bg-slate-50 text-slate-900 font-['Inter',sans-serif] antialiased">
    <nav class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-slate-200 px-6 py-4 flex justify-between items-center">
      <div class="flex items-center gap-2">
        <img src="/icon.svg" class="w-8 h-8" alt="Logo" />
        <span class="font-extrabold tracking-tight text-xl bg-clip-text text-transparent bg-gradient-to-r from-indigo-600 to-violet-600">
          UK 2026
        </span>
      </div>
      <PanicButton client:load />
    </nav>

    <slot />

    <footer class="mt-20 py-10 text-center text-slate-400 text-sm border-t border-slate-200">
      <p>Curso de Verano Aplicado a IA • University of Hertfordshire</p>
      <p class="mt-1">© 2026 - Daniel Rojas</p>
    </footer>
  </body>
</html>