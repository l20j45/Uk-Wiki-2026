---
// src/layouts/BlogPostLayout.astro
import Layout from './Layout.astro';
const { frontmatter } = Astro.props;
---
<Layout title={frontmatter.title}>
  <article class="max-w-2xl mx-auto px-6 py-16">
    <header class="mb-12 border-b border-slate-100 pb-12">
      <div class="flex items-center gap-3 text-slate-400 text-sm font-medium mb-4">
        <time>{frontmatter.pubDate}</time>
        <span>•</span>
        <span class="capitalize">{frontmatter.category}</span>
      </div>
      <h1 class="text-5xl font-black text-slate-900 leading-[1.1] mb-6">
        {frontmatter.title}
      </h1>
      <p class="text-xl text-slate-500 leading-relaxed italic">
        {frontmatter.description}
      </p>
    </header>

    <div class="prose prose-slate prose-indigo prose-lg max-w-none 
                prose-headings:font-black prose-headings:tracking-tight
                prose-img:rounded-3xl prose-img:shadow-lg
                prose-a:text-indigo-600 prose-a:no-underline hover:prose-a:underline">
      <slot />
    </div>

    <div class="mt-20 pt-10 border-t border-slate-100 flex justify-between items-center">
      <a href="/blog" class="text-slate-400 hover:text-indigo-600 font-bold transition-colors">
        ← Volver a la biblioteca
      </a>
      <button onclick="window.scrollTo({top: 0, behavior: 'smooth'})" class="p-3 bg-slate-50 rounded-full hover:bg-indigo-50 transition-colors">
        🔝
      </button>
    </div>
  </article>
</Layout>