---
// src/components/UserQR.astro
const { username, size = "200x200" } = Astro.props;

// La URL base de tu proyecto (Cámbiala por tu dominio real de Netlify)
const baseUrl = "https://tu-wiki-uk-2026.netlify.app";
const profileUrl = `${baseUrl}/user/${username}`;


// Endpoint de la API de QR
const qrSource = `https://api.qrserver.com/v1/create-qr-code/?size=${size}&data=${encodeURIComponent(profileUrl)}&bgcolor=ffffff&color=4f46e5&margin=2`;
---

<div class="flex flex-col items-center gap-4 p-6 bg-white dark:bg-slate-800 rounded-[2.5rem] shadow-inner border border-slate-100 dark:border-slate-700">
  <div class="relative group">
    <img 
      src={qrSource} 
      alt={`QR de ${username}`} 
      class="rounded-2xl shadow-lg group-hover:scale-105 transition-transform duration-300"
    />
    <div class="absolute inset-0 border-2 border-indigo-500/20 rounded-2xl pointer-events-none"></div>
  </div>
  
  <p class="text-[10px] font-black uppercase tracking-widest text-slate-400">
    Escanea para ver perfil
  </p>
</div>