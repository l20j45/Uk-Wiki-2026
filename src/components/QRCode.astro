---
// src/components/QRCode.astro
const { qrUrl, username } = Astro.props;
---

<div class="flex flex-col items-center p-4 bg-white dark:bg-slate-800 rounded-[2.5rem] shadow-sm">
  {qrUrl ? (
    <img 
      src={qrUrl} 
      alt={`QR Estático de ${username}`} 
      class="w-48 h-48 rounded-2xl shadow-md"
    />
  ) : (
    <div class="w-48 h-48 border-2 border-dashed border-slate-200 rounded-2xl flex flex-col items-center justify-center text-center p-4">
      <p class="text-[10px] font-black text-slate-400 uppercase">QR No generado</p>
      <form action="/api/user/generate-qr" method="POST" class="mt-2">
        <button class="text-[10px] bg-indigo-600 text-white px-3 py-1 rounded-full font-bold">Generar ahora</button>
      </form>
    </div>
  )}
  
</div>