---
import { db } from '../db/db';
import { itinerary } from '../db/schema';
import Layout from "../layouts/Layout.astro";
import { eq, asc } from 'drizzle-orm';

// 1. Obtener parámetros y tiempo actual
const dateParam = Astro.url.searchParams.get('date') || '';
const now = new Date();

// Obtenemos hora y fecha actual para comparar
const currentFullDate = now.toISOString().split('T')[0];
const currentHour = now.getHours();

// 2. Consultar la DB
let itineraryData;

if (dateParam) {
  itineraryData = await db.select()
    .from(itinerary)
    .where(eq(itinerary.eventDate, dateParam))
    .orderBy(asc(itinerary.eventTime));
} else {
  itineraryData = await db.select()
    .from(itinerary)
    .orderBy(asc(itinerary.eventDate), asc(itinerary.eventTime));
}

const isFiltered = dateParam !== '';
---

<Layout title="Itinerario Completo | UK 2026">
  <main class="max-w-2xl mx-auto px-6 py-12 pb-32 bg-white">
    
    <header class="mb-16">
      <div class="flex items-center gap-3 mb-4">
        <span class="px-3 py-1 bg-indigo-100 text-indigo-600 text-[10px] font-black uppercase tracking-widest rounded-full">
          Timeline Oficial
        </span>
      </div>
      <h1 class="text-4xl font-black text-slate-900 tracking-tight">
        {isFiltered ? `Plan para el ${dateParam}` : 'Cronograma de Actividades'}
      </h1>
      <p class="text-slate-500 mt-3 italic text-lg leading-relaxed">
        "Un viaje de mil millas comienza con un solo paso... y un buen Dashboard."
      </p>
      
      {isFiltered && (
        <a href="/itinerario" class="inline-flex items-center mt-6 text-sm font-bold text-indigo-600 hover:gap-2 transition-all">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7 7-7" />
          </svg>
          Ver todo el viaje
        </a>
      )}
    </header>

    <div class="relative">
      <div class="absolute left-8 top-0 bottom-0 w-0.5 bg-slate-100"></div>

      <div class="space-y-14">
        {itineraryData.length > 0 ? (
          itineraryData.map((item) => {
            const itemHour = parseInt(item.eventTime.split(':')[0]);
            const isToday = item.eventDate === currentFullDate;
            const isNow = isToday && (itemHour === currentHour);

            return (
              <div class="relative pl-24 group">
                
                {isNow && (
                  <div class="absolute left-[1.85rem] top-7 flex h-3.5 w-3.5 z-30">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-rose-400 opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-3.5 w-3.5 bg-rose-600 shadow-[0_0_15px_rgba(225,29,72,0.4)]"></span>
                  </div>
                )}

                {isToday && !isNow && (
                  <span class="absolute left-[2.1rem] top-8 w-2 h-2 bg-emerald-500 rounded-full z-20 opacity-40"></span>
                )}
                
                <div class={`absolute left-0 top-0 w-16 h-16 rounded-[1.5rem] flex items-center justify-center text-2xl shadow-sm border-4 transition-all z-10 bg-white
                  ${isNow 
                    ? 'border-rose-100 scale-110 shadow-rose-100' 
                    : 'border-slate-50 group-hover:border-indigo-100'
                  }`}>
                  {item.icon || "📍"}
                </div>

                <div class={`transition-all ${isNow ? 'translate-x-2' : ''}`}>
                  <div class="flex items-center gap-2 mb-1">
                    <span class={`text-[10px] font-black uppercase tracking-[0.2em] ${isNow ? 'text-rose-600 animate-pulse' : 'text-indigo-500'}`}>
                      {isNow ? '• En curso ahora' : `${item.eventDate} — ${item.eventTime}`}
                    </span>
                  </div>
                  
                  <h3 class={`text-xl font-bold transition-colors ${isNow ? 'text-slate-900' : 'text-slate-700 group-hover:text-indigo-600'}`}>
                    {item.title}
                  </h3>
                  
                  <p class="text-slate-500 mt-2 text-sm leading-relaxed max-w-md">
                    {item.description}
                  </p>

                  {item.location && (
                    <div class="mt-4 inline-flex items-center px-3 py-1 bg-slate-50 border border-slate-100 rounded-full">
                      <span class="text-[10px] font-bold text-slate-400 uppercase tracking-tight">
                        📍 {item.location}
                      </span>
                    </div>
                  )}
                </div>
                
                <div class={`absolute left-16 top-8 w-8 h-0.5 transition-colors ${isNow ? 'bg-rose-100' : 'bg-slate-100'}`}></div>
              </div>
            )
          })
        ) : (
          <div class="pl-24 py-10">
            <div class="p-8 bg-slate-50 rounded-[2rem] border-2 border-dashed border-slate-200 text-center">
               <p class="text-slate-400 font-medium italic">No hay misiones programadas.</p>
            </div>
          </div>
        )}
      </div>
    </div>

    <footer class="mt-24 p-10 bg-indigo-600 rounded-[3rem] text-white shadow-xl shadow-indigo-100 relative overflow-hidden">
      <div class="relative z-10">
        <h4 class="text-lg font-bold mb-3 flex items-center gap-2">
          <span class="bg-white/20 p-1.5 rounded-lg text-sm">📅</span> 
          Sincronización de Horarios
        </h4>
        <p class="text-indigo-100 text-xs leading-relaxed opacity-90">
          Basado en la hora local de <strong>Londres (BST)</strong>. 
          El indicador rojo se activa automáticamente durante la hora de inicio de la actividad.
        </p>
      </div>
      <div class="absolute -right-10 -bottom-10 w-40 h-40 bg-white/10 rounded-full blur-3xl"></div>
    </footer>

  </main>
</Layout>