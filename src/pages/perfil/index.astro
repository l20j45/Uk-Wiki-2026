---
import Layout from "../../layouts/Layout.astro";

import { db } from "../../db/db";
import { users, socialProfiles } from "../../db/schema";
import { eq } from "drizzle-orm";
import QRCode from "../../components/QRCode.astro";

// 1. Obtener usuario de la sesión (inyectado por middleware)
// Usamos Astro.locals
const user = Astro.locals.user;

// Si necesitas la cookie directamente por algo extra:
const session = Astro.cookies.get("user_session");

if (!user) {
  return Astro.redirect("/login");
}

// 2. Traer info extendida (Redes Sociales)
const userData = await db.query.users.findFirst({
  where: eq(users.id, user.id),
  with: {
    socials: true,
  },
});

const initials = userData?.fullName
  .split(" ")
  .map((n) => n[0])
  .join("")
  .toUpperCase();
---

<Layout title={`Perfil | ${userData?.fullName}`}>
  <main class="max-w-2xl mx-auto px-6 py-10 pb-32">
    <button class="px-4 py-2 bg-rose-50 text-rose-600 rounded-xl text-sm font-bold hover:bg-rose-100 transition-colors">
      <a href="/perfil/editar">Editar Perfil</a>
    </button>
    <section class="text-center mb-10">
      
      <div class="relative inline-block">
        </p>
        <div
          class="w-60 h-60 bg-white/20 rounded-2xl mx-auto flex items-center justify-center text-2xl font-black backdrop-blur-md"
        >
          <img
            src={user.avatarUrl?.replace(
              "/upload/",
              "/upload/w_500,h_500,c_thumb,g_face/",
            )}
            alt="Foto ID"
            class="rounded-xl"
          />
        </div>
        <span
          class="absolute bottom-2 right-0 bg-emerald-500 border-4 border-white dark:border-slate-950 w-6 h-6 rounded-full"
        ></span>
      </div>

      <h1
        class="text-2xl font-black text-slate-900 dark:text-white leading-none"
      >
        {userData?.fullName}
      </h1>
      <p class="text-indigo-500 font-bold text-sm mt-1">
        @{userData?.username}
      </p>

      <div class="mt-4 flex justify-center gap-2">
        <span
          class="px-3 py-1 rounded-full bg-slate-100 dark:bg-slate-800 text-[10px] font-black uppercase tracking-widest text-slate-500"
        >
          {userData?.role}
        </span>
      </div>
    </section>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="space-y-6">
        <div
          class="bg-white dark:bg-slate-900 p-6 rounded-[2.5rem] border border-slate-100 dark:border-slate-800 shadow-sm"
        >
          <h3 class="text-xs font-black uppercase text-slate-400 mb-3 ml-1">
            Biografía
          </h3>
          <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">
            {
              userData?.bio ||
                "Sin biografía aún. ¡Cuéntanos algo sobre ti para el viaje!"
            }
          </p>
        </div>

        <div
          class="bg-white dark:bg-slate-900 p-6 rounded-[2.5rem] border border-slate-100 dark:border-slate-800 shadow-sm"
        >
          <div class="flex justify-between items-center mb-4 ml-1">
            <h3 class="text-xs font-black uppercase text-slate-400">
              Redes Sociales
            </h3>
            <a
              href="/perfil/editar"
              class="text-[10px] font-bold text-indigo-600 uppercase">Editar</a
            >
          </div>

          <div class="space-y-2">
            {
              userData?.socials.map((social) => (
                <a
                  href={social.url}
                  target="_blank"
                  class="flex items-center justify-between p-3 bg-slate-50 dark:bg-slate-800/50 rounded-2xl hover:bg-indigo-50 transition-colors group"
                >
                  <span class="text-sm font-bold text-slate-700 dark:text-slate-300">
                    {social.platform}
                  </span>
                  <span class="text-indigo-400 opacity-0 group-hover:opacity-100 transition-opacity">
                    ↗
                  </span>
                </a>
              ))
            }
            {
              userData?.socials.length === 0 && (
                <p class="text-xs text-slate-400 italic text-center py-2">
                  No has agregado redes.
                </p>
              )
            }
          </div>
        </div>
      </div>

      <div class="space-y-6">
        <div
          class="bg-white dark:bg-slate-900 p-2 rounded-[2.5rem] border border-slate-100 dark:border-slate-800 shadow-sm"
        >
          {userData && <QRCode qrUrl={userData.qrUrl} username={userData.username} />}
        </div>

        <form action="/api/auth/logout" method="POST">
          <button
            type="submit"
            class="w-full p-4 rounded-2xl border-2 border-rose-100 dark:border-rose-900/30 text-rose-500 font-black uppercase text-xs tracking-widest hover:bg-rose-50 dark:hover:bg-rose-900/10 transition-all"
          >
            Cerrar Sesión
          </button>
        </form>
      </div>
    </div>
  </main>
</Layout>
