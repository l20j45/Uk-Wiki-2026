---
import Layout from "../../layouts/Layout.astro";
import { db } from '../../db/db';
import { articles } from '../../db/schema';
import { eq } from 'drizzle-orm';
import { marked } from 'marked'; 

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/404');
}

const [post] = await db.select().from(articles).where(eq(articles.slug, slug));

if (!post) {
  return Astro.redirect('/404');
}

const contentHtml = marked.parse(post.content || '');
---

<Layout title={post.title}>
  <main class="max-w-2xl mx-auto px-6 py-12">
    <header class="mb-8">
      <span class="text-indigo-600 font-bold uppercase tracking-widest text-xs">
        {post.category}
      </span>
      <h1 class="text-4xl font-black text-slate-900 mt-2">
        {post.title}
      </h1>
      <p class="text-slate-500 mt-4 text-xl italic">
        {post.description}
      </p>
    </header>

    <hr class="my-8 border-slate-100" />

    <article class="prose prose-slate max-w-none" set:html={contentHtml} />
  </main>
</Layout>

<style is:global>
  /* Si NO usas el plugin de Tailwind Typography, añade estos estilos 
     para que los números y puntos se vean: */
  .prose h1 { font-size: 2.25rem; font-weight: 900; margin-bottom: 1.5rem; }
  .prose h3 { font-size: 1.5rem; font-weight: 700; margin-top: 2rem; }
  .prose ul { list-style-type: disc; margin-left: 1.5rem; margin-bottom: 1rem; }
  .prose li { margin-bottom: 0.5rem; }
  .prose strong { font-weight: bold; color: #4f46e5; }
</style>