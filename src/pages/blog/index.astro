---
import Layout from "../../layouts/Layout.astro";
import SearchWiki from "../../components/SearchWiki.jsx";
import BlogPostLayout from "../../layouts/BlogPostLayout.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog");
---

<Layout title="Wiki de Aprendizaje | UK 2026">
  <main class="max-w-2xl mx-auto px-6 py-12">
    <div class="mb-12">
      <h3 class="text-4xl font-black text-slate-900 tracking-tight">
        Biblioteca de Recursos
      </h3>

      <p class="text-slate-500 mt-2">
        Todo el material académico y logístico en un solo lugar.
      </p>
    </div>
          <h4 class="mt-5 text-xl font-black text-slate-900 tracking-tight">
        Busqueda de articulo
      </h4>
    <SearchWiki client:load posts={allPosts} />

    <div class="space-y-8">
      {
        allPosts.map((post) => (
          <a href={`/blog/${post.id}`} class="group block">
            <article class="relative p-1">
              {post.data.isUrgent && (
                <span
                  class={`inline-block px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest mb-3 
                  bg-rose-100 text-rose-600
                }`}
                >
                  URGENTE
                </span>
              )}
              <span
                class={`inline-block px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest mb-3 bg-indigo-100 text-indigo-600
            }`}
              >
                {post.data.category}
              </span>
              <h2 class="text-2xl font-bold text-slate-800 group-hover:text-indigo-600 transition-colors">
                {post.data.title}
              </h2>
              <p class="text-slate-500 mt-2 leading-relaxed">
                {post.data.description}
              </p>
              <div class="mt-4 flex items-center text-indigo-600 font-bold text-sm">
                Leer más{" "}
                <span class="ml-2 group-hover:translate-x-2 transition-transform">
                  →
                </span>
              </div>
              <div class="absolute -left-6 top-0 bottom-0 w-1 bg-indigo-600 scale-y-0 group-hover:scale-y-100 transition-transform origin-top rounded-full" />
            </article>
          </a>
        ))
      }
    </div>
  </main>
</Layout>
