---
import Layout from '../layouts/Layout.astro';
import DailySchedule from '../components/DailySchedule.jsx';
---

<Layout title="Dashboard | UK 2026">
  <main class="max-w-2xl mx-auto px-6 pt-12 pb-24">
    
    <header class="mb-10">
      <h1 class="text-4xl font-extrabold tracking-tight text-slate-900">
        ¡Bienvenido, <span class="text-indigo-600">Daniel</span>!
      </h1>
      <p class="text-lg text-slate-500 mt-2 font-medium">Todo listo para tu estancia en Hatfield.</p>
    </header>

    <div class="mb-12 transform hover:scale-[1.02] transition-transform duration-300">
      <DailySchedule client:load />
    </div>

    <h2 class="text-xs font-bold uppercase tracking-widest text-slate-400 mb-4">Recursos Principales</h2>
    
    <div class="grid grid-cols-2 gap-4">
      <a href="/blog" class="group p-6 bg-white rounded-3xl border border-slate-200 shadow-sm hover:shadow-xl hover:border-indigo-200 transition-all">
        <div class="w-12 h-12 bg-indigo-50 rounded-2xl flex items-center justify-center text-2xl mb-4 group-hover:scale-110 transition-transform">
          📚
        </div>
        <h3 class="font-bold text-slate-800">Wiki de IA</h3>
        <p class="text-xs text-slate-500 mt-1">Módulos y lecturas del curso.</p>
      </a>

      <!-- <a href="/itinerario" class="group p-6 bg-white rounded-3xl border border-slate-200 shadow-sm hover:shadow-xl hover:border-indigo-200 transition-all">
        <div class="w-12 h-12 bg-emerald-50 rounded-2xl flex items-center justify-center text-2xl mb-4 group-hover:scale-110 transition-transform">
          📅
        </div>
        <h3 class="font-bold text-slate-800">Itinerario</h3>
        <p class="text-xs text-slate-500 mt-1">Calendario completo de actividades.</p>
      </a> -->

      <!-- <a href="/transporte" class="group p-6 bg-white rounded-3xl border border-slate-200 shadow-sm hover:shadow-xl hover:border-indigo-200 transition-all">
        <div class="w-12 h-12 bg-amber-50 rounded-2xl flex items-center justify-center text-2xl mb-4 group-hover:scale-110 transition-transform">
          🚇
        </div>
        <h3 class="font-bold text-slate-800">Transporte</h3>
        <p class="text-xs text-slate-500 mt-1">Cómo moverte en Londres y París.</p>
      </a> -->

      <a href="/preparacion" class="group p-6 bg-white rounded-3xl border border-slate-200 shadow-sm hover:shadow-xl hover:border-indigo-200 transition-all">
        <div class="w-12 h-12 bg-rose-50 rounded-2xl flex items-center justify-center text-2xl mb-4 group-hover:scale-110 transition-transform">
          🧳
        </div>
        <h3 class="font-bold text-slate-800">Checklist</h3>
        <p class="text-xs text-slate-500 mt-1">Maleta y documentos listos.</p>
      </a>
    </div>

    <div class="mt-12 p-6 bg-slate-900 rounded-[2rem] text-white overflow-hidden relative">
      <div class="relative z-10">
        <h3 class="text-xl font-bold mb-2">¿Necesitas ayuda?</h3>
        <p class="text-slate-400 text-sm mb-4">Accede a los números de emergencia y soporte de la UdeG.</p>
        <a href="/sos" class="inline-block bg-white text-slate-900 px-6 py-3 rounded-full font-bold text-sm hover:bg-indigo-50 transition-colors">
          Contactar Soporte
        </a>
      </div>
      <div class="absolute -right-10 -bottom-10 w-40 h-40 bg-indigo-600 rounded-full blur-3xl opacity-50"></div>
    </div>

  </main>
</Layout>