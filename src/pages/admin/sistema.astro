---
import Layout from "../../layouts/Layout.astro";
import { db } from "../../db/db";
import { users, articles, itinerary } from "../../db/schema";
import { sql } from "drizzle-orm";

// 1. Protección de Ruta (Solo Admins)
const user = Astro.locals.user;


// 2. Métricas de Base de Datos
const startTime = performance.now();
const userCount = await db.select({ count: sql`count(*)` }).from(users);
const articleCount = await db.select({ count: sql`count(*)` }).from(articles);
const eventCount = await db.select({ count: sql`count(*)` }).from(itinerary);
const dbLatency = Math.round(performance.now() - startTime);

// 3. Verificación de Cloudinary (Health Check)
let cloudinaryStatus = "Online";
let cloudLatency = 0;
try {
  const cldStart = performance.now();
  const res = await fetch(`https://res.cloudinary.com/${import.meta.env.CLOUDINARY_CLOUD_NAME}/image/upload/sample.jpg`, { method: 'HEAD' });
  if (!res.ok) throw new Error();
  cloudLatency = Math.round(performance.now() - cldStart);
} catch (e) {
  cloudinaryStatus = "Offline";
}

// 4. Info del Entorno
const nodeVersion = process.version;
const envMode = import.meta.env.MODE;
---

<Layout title="System Status | Admin">
  <main class="max-w-4xl mx-auto px-6 py-12 pb-32 bg-white">
    
    <header class="mb-12">
      <a href="/admin" class="text-[10px] font-black uppercase text-indigo-600 tracking-widest mb-4 block">← Volver al Panel</a>
      <div class="flex items-center gap-4">
        <h1 class="text-4xl font-black text-slate-900 tracking-tight">System Health</h1>
        <span class="flex h-3 w-3 relative">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-3 w-3 bg-emerald-500"></span>
        </span>
      </div>
      <p class="text-slate-400 font-bold text-xs uppercase mt-2 tracking-tighter">Monitoreo de infraestructura UK Wiki 2026</p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      
      <section class="bg-slate-50 p-8 rounded-[2.5rem] border border-slate-100 shadow-sm col-span-2">
        <div class="flex justify-between items-start mb-6">
          <h3 class="text-[10px] font-black uppercase text-slate-400 tracking-widest">Database (SQLite/Drizzle)</h3>
          <span class="px-3 py-1 bg-emerald-100 text-emerald-600 rounded-full text-[9px] font-black uppercase">Active</span>
        </div>
        
        <div class="grid grid-cols-3 gap-4 mb-8">
          <div class="text-center">
            <p class="text-2xl font-black text-slate-900">{userCount[0].count}</p>
            <p class="text-[9px] font-bold text-slate-400 uppercase">Usuarios</p>
          </div>
          <div class="text-center border-x border-slate-200">
            <p class="text-2xl font-black text-slate-900">{articleCount[0].count}</p>
            <p class="text-[9px] font-bold text-slate-400 uppercase">Wikis</p>
          </div>
          <div class="text-center">
            <p class="text-2xl font-black text-slate-900">{eventCount[0].count}</p>
            <p class="text-[9px] font-bold text-slate-400 uppercase">Eventos</p>
          </div>
        </div>

        <div class="flex items-center gap-2 p-4 bg-white rounded-2xl border border-slate-100">
          <span class="text-xs">⚡</span>
          <p class="text-[10px] font-bold text-slate-500 uppercase tracking-tight">Latencia de respuesta: <span class="text-indigo-600">{dbLatency}ms</span></p>
        </div>
      </section>

      <section class="bg-white p-8 rounded-[2.5rem] border border-slate-100 shadow-sm">
        <h3 class="text-[10px] font-black uppercase text-slate-400 tracking-widest mb-6">Media Storage</h3>
        <div class="flex flex-col items-center justify-center py-4">
          <div class={`text-4xl mb-2 ${cloudinaryStatus === 'Online' ? 'grayscale-0' : 'grayscale text-slate-300'}`}>☁️</div>
          <p class="text-sm font-black text-slate-800">Cloudinary</p>
          <p class={`text-[10px] font-bold uppercase mt-1 ${cloudinaryStatus === 'Online' ? 'text-emerald-500' : 'text-rose-500'}`}>{cloudinaryStatus}</p>
        </div>
        {cloudinaryStatus === 'Online' && (
           <p class="text-[9px] text-center text-slate-400 font-bold mt-4 uppercase">Ping: {cloudLatency}ms</p>
        )}
      </section>

      <section class="bg-slate-900 p-8 rounded-[2.5rem] text-white md:col-span-3 grid grid-cols-1 md:grid-cols-4 gap-8">
        <div>
          <p class="text-[9px] font-black uppercase text-slate-500 tracking-[0.2em] mb-2">Node Version</p>
          <p class="text-sm font-mono text-indigo-400">{nodeVersion}</p>
        </div>
        <div>
          <p class="text-[9px] font-black uppercase text-slate-500 tracking-[0.2em] mb-2">Environment</p>
          <p class="text-sm font-black uppercase tracking-widest">{envMode}</p>
        </div>
        <div>
          <p class="text-[9px] font-black uppercase text-slate-500 tracking-[0.2em] mb-2">Server Location</p>
          <p class="text-sm font-black uppercase tracking-widest">Vercel Edge (Global)</p>
        </div>
        <div class="text-right flex flex-col justify-end">
          <p class="text-[8px] font-bold text-slate-600 uppercase">Last Check</p>
          <p class="text-[10px] font-mono text-slate-400">{new Date().toLocaleTimeString()}</p>
        </div>
      </section>

    </div>

    <div class="mt-8 bg-slate-50 p-8 rounded-[2.5rem] border border-slate-100">
       <h3 class="text-[10px] font-black uppercase text-slate-400 tracking-widest mb-4 ml-2">Security Audit</h3>
       <div class="space-y-3 font-mono text-[10px]">
         <div class="flex gap-4 text-emerald-600 italic">
           <span>[OK]</span>
           <span>Auth Middleware inyeccion completa.</span>
         </div>
         <div class="flex gap-4 text-emerald-600 italic">
           <span>[OK]</span>
           <span>SQLite connection pool estable.</span>
         </div>
         <div class="flex gap-4 text-slate-400 italic">
           <span>[INFO]</span>
           <span>Sesion de Admin detectada para {user.username}.</span>
         </div>
       </div>
    </div>

  </main>
</Layout>