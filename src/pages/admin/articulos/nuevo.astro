---
import Layout from "../../../layouts/Layout.astro";
import WikiEditor from "../../../components/WikiEditor";
import { db } from "../../../db/db";
import { articles } from "../../../db/schema";

if (Astro.request.method === "POST") {
  const data = await Astro.request.formData();
  const title = data.get("title")?.toString() || "";
  
  // Generar slug automático
  const slug = title.toLowerCase()
    .normalize("NFD").replace(/[\u0300-\u036f]/g, "") // Quitar acentos
    .replace(/\s+/g, '-')
    .replace(/[^\w-]+/g, '');

  await db.insert(articles).values({
    title,
    slug,
    description: data.get("description")?.toString(),
    content: data.get("content")?.toString() || "",
    category: data.get("category")?.toString() || "General",
    importance: parseInt(data.get("importance")?.toString() || "1"),
    isUrgent: parseInt(data.get("isUrgent")?.toString() || "0"),
    image: data.get("image")?.toString(),
    pubDate: new Date().toLocaleDateString('es-MX'), // O la fecha de Londres
  });

  return Astro.redirect("/admin/");
}
---

<Layout title="Nueva Wiki | Admin">
  <main class="max-w-5xl mx-auto px-6 py-12">
    <header class="mb-10">
      <a href="/admin" class="text-[10px] font-black uppercase text-indigo-600 tracking-widest mb-4 block">← Panel</a>
      <h1 class="text-3xl font-black text-slate-900 leading-tight">Redactar Guía de Viaje</h1>
    </header>

    <form method="POST">
      <WikiEditor client:only="react" />
    </form>
  </main>
</Layout>