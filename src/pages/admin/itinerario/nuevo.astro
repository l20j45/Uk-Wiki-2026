---
import Layout from "../../../layouts/Layout.astro";
---

<Layout title="Nuevo Evento | Staff">
  <main class="max-w-xl mx-auto p-6">
    <div class="bg-white dark:bg-slate-900 p-8 rounded-[3rem] shadow-2xl border border-slate-100 dark:border-slate-800">
      <header class="mb-8 text-center">
        <span class="text-4xl">📅</span>
        <h1 class="text-2xl font-black mt-4 text-slate-900 ">Agregar Actividad</h1>
      </header>

      <form action="/api/itinerary" method="POST" class="space-y-5">
        <div>
          <label class="text-xs font-black uppercase text-slate-400 ml-2">Título del Evento</label>
          <input type="text" name="title" placeholder="Ej: Visita al British Museum" required
                 class="w-full p-4 bg-slate-50  rounded-2xl border-none ring-indigo-500 focus:ring-2 outline-none " />
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="text-xs font-black uppercase text-slate-400 ml-2">Fecha</label>
            <input type="date" name="eventDate" required
                   class="w-full p-4 bg-slate-50  rounded-2xl border-none ring-indigo-500 focus:ring-2 outline-none " />
          </div>
          <div>
            <label class="text-xs font-black uppercase text-slate-400 ml-2">Hora (LDN)</label>
            <input type="time" name="eventTime" required
                   class="w-full p-4 bg-slate-50  rounded-2xl border-none ring-indigo-500 focus:ring-2 outline-none " />
          </div>
        </div>

        <div>
          <label class="text-xs font-black uppercase text-slate-400 ml-2">Icono (Emoji)</label>
          <input type="text" name="icon" placeholder="🏛️" 
                 class="w-full p-4 bg-slate-50  rounded-2xl border-none ring-indigo-500 focus:ring-2 outline-none " />
        </div>

        <div>
          <label class="text-xs font-black uppercase text-slate-400 ml-2">Descripción / Notas</label>
          <textarea name="description" rows="3" placeholder="Punto de reunión: Entrada principal..."
                    class="w-full p-4 bg-slate-50 rounded-2xl border-none ring-indigo-500 focus:ring-2 outline-none "></textarea>
        </div>

        <button type="submit" class="w-full bg-indigo-600 text-white font-black py-5 rounded-2xl hover:bg-indigo-700 transition-all shadow-xl shadow-indigo-100 dark:shadow-none uppercase tracking-widest text-sm">
          Publicar en la Wiki
        </button>
      </form>
    </div>
  </main>
</Layout>