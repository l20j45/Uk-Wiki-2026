---
import Layout from "../../../../layouts/Layout.astro";
import { db } from "../../../../db/db";
import { users } from "../../../../db/schema";
import { eq } from "drizzle-orm";

const { id } = Astro.params;
const userId = parseInt(id || "");

if (isNaN(userId)) return Astro.redirect("/admin");

const userData = await db.query.users.findFirst({
  where: eq(users.id, userId),
});

if (!userData) return Astro.redirect("/admin?error=user_not_found");

// 2. Manejar el POST de actualización
let message = "";

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const fullName = formData.get("fullName")?.toString();
  const email = formData.get("email")?.toString();
  const phone = formData.get("phone")?.toString();
  const role = formData.get("role")?.toString() as "admin" | "user";
  const qrUrl = formData.get("qrUrl")?.toString();

  try {
    await db
      .update(users)
      .set({ fullName, email, phone, role, qrUrl })
      .where(eq(users.id, userId));

    return Astro.redirect("/admin?success=user_updated");
  } catch (e) {
    message = "Error al actualizar los datos en la base de datos.";
  }
}
---

<Layout title={`Editando a ${userData.username} | Admin`}>
  <main class="max-w-3xl mx-auto px-6 py-12 pb-32 bg-white">
    <header class="mb-10 flex justify-between items-start">
      <div>
        <a
          href="/admin"
          class="text-[10px] font-black uppercase text-indigo-600 hover:underline mb-4 block tracking-widest"
        >
          ← Volver al Panel
        </a>
        <h1 class="text-3xl font-black text-slate-900 tracking-tight">
          Editar Usuario
        </h1>
        <p class="text-slate-500 mt-1 italic">
          Modificando perfil de <span class="font-bold text-slate-700"
            >@{userData.username}</span>
        </p>
      </div>

      <div
        class="w-16 h-16 bg-slate-50 rounded-2xl border border-slate-100 flex items-center justify-center text-2xl shadow-sm"
      >
        {
          userData.avatarUrl ? (
            <img
              src={userData.avatarUrl}
              class="w-full h-full object-cover rounded-2xl"
            />
          ) : (
            "👤"
          )
        }
      </div>
    </header>

    {
      message && (
        <div class="p-4 mb-8 bg-rose-50 text-rose-600 rounded-2xl text-xs font-bold border border-rose-100 italic">
          ⚠️ {message}
        </div>
      )
    }

    <form method="POST" class="space-y-8">
      <section
        class="bg-white p-8 rounded-[2.5rem] border border-slate-100 shadow-sm space-y-6"
      >
        <h3
          class="text-[10px] font-black uppercase text-indigo-500 tracking-widest ml-2"
        >
          Datos de Identidad
        </h3>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label
              class="block text-[10px] font-black uppercase text-slate-400 mb-2 ml-2 tracking-tighter"
              >Nombre Completo</label
            >
            <input
              type="text"
              name="fullName"
              value={userData.fullName}
              class="w-full p-4 bg-slate-50 rounded-2xl border-none ring-1 ring-slate-100 focus:ring-2 focus:ring-indigo-500 outline-none transition-all text-sm font-medium"
            />
          </div>
          <div>
            <label
              class="block text-[10px] font-black uppercase text-slate-400 mb-2 ml-2 tracking-tighter"
              >Email Institucional</label
            >
            <input
              type="email"
              name="email"
              value={userData.email}
              class="w-full p-4 bg-slate-50 rounded-2xl border-none ring-1 ring-slate-100 focus:ring-2 focus:ring-indigo-500 outline-none transition-all text-sm font-medium"
            />
          </div>
        </div>

        <div>
          <label
            class="block text-[10px] font-black uppercase text-slate-400 mb-2 ml-2 tracking-tighter"
            >Teléfono / WhatsApp</label
          >
          <input
            type="text"
            name="phone"
            value={userData.phone}
            placeholder="+52..."
            class="w-full p-4 bg-slate-50 rounded-2xl border-none ring-1 ring-slate-100 focus:ring-2 focus:ring-indigo-500 outline-none transition-all text-sm font-medium"
          />
        </div>
      </section>

      <section
        class="bg-slate-50 p-8 rounded-[2.5rem] border border-slate-100 space-y-6"
      >
        <h3
          class="text-[10px] font-black uppercase text-slate-400 tracking-widest ml-2"
        >
          Configuración de Sistema
        </h3>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label
              class="block text-[10px] font-black uppercase text-slate-400 mb-3 ml-2 tracking-tighter"
              >Nivel de Acceso</label
            >
            <select
              name="role"
              class="w-full p-4 bg-white rounded-2xl border-none ring-1 ring-slate-200 focus:ring-2 focus:ring-indigo-500 outline-none font-bold text-xs uppercase tracking-widest"
            >
              <option value="user" selected={userData.role === "user"}
                >🎓 Alumno</option
              >
              <option value="admin" selected={userData.role === "admin"}
                >🔑 Administrador</option
              >
            </select>
          </div>

          <div>
            <label
              class="block text-[10px] font-black uppercase text-slate-400 mb-2 ml-2 tracking-tighter"
              >URL del QR (Manual)</label
            >
            <input
              type="text"
              name="qrUrl"
              value={userData.qrUrl}
              placeholder="https://cloudinary.com/..."
              class="w-full p-4 bg-white rounded-2xl border-none ring-1 ring-slate-200 focus:ring-2 focus:ring-indigo-500 outline-none transition-all text-xs text-slate-400"
            />
          </div>
        </div>
      </section>

      <div class="flex flex-col md:flex-row gap-4 pt-4">
        <button
          type="submit"
          class="flex-1 bg-slate-900 text-white font-black py-6 rounded-[2rem] shadow-xl hover:bg-indigo-600 transition-all uppercase tracking-[0.2em] text-[10px]"
        >
          Guardar Cambios
        </button>
        <button
          type="button"
          onclick="history.back()"
          class="px-10 bg-white border border-slate-200 text-slate-400 font-black py-6 rounded-[2rem] hover:bg-slate-50 transition-all uppercase tracking-[0.2em] text-[10px]"
        >
          Cancelar
        </button>
      </div>
    </form>
  </main>
</Layout>
