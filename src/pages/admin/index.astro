---
import Layout from "../../layouts/Layout.astro";
import { db } from "../../db/db";
import { users, itinerary } from "../../db/schema";
import { desc, asc } from "drizzle-orm";
import EventAdminTable from "../../components/EventAdminTable";
import UserAdminTable from "../../components/UserAdminTable";

const totalEvents = await db
  .select()
  .from(itinerary)
  .orderBy(asc(itinerary.eventDate));

// 3. Obtener últimos usuarios registrados
const recentUsers = await db.query.users.findMany({
  orderBy: [desc(users.id)],
});
const tableUser = recentUsers.map((u) => ({
  id: u.id,
  username: u.username,
  fullName: u.fullName,
  role: u.role,
  qrUrl: u.qrUrl ?? "pendiente",
  image: u.avatarUrl,
}));


console.log("🚀 ~ tableUser:", tableUser)

