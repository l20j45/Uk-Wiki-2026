---
import Layout from "../../layouts/Layout.astro";
import { db } from "../../db/db";
import { users, itinerary, articles } from "../../db/schema";
import { desc, asc } from "drizzle-orm";
import EventAdminTable from "../../components/EventAdminTable";
import UserAdminTable from "../../components/UserAdminTable";
import ArticlesAdminTable from "../../components/ArticlesAdminTable";
import BackToTop from "../../components/BackToTop.astro";

const totalEvents = await db
  .select()
  .from(itinerary)
  .orderBy(asc(itinerary.eventDate));

const totalArticles = await db
  .select()
  .from(articles)
  .orderBy(asc(articles.id));

const recentUsers = await db.query.users.findMany({
  orderBy: [desc(users.id)],
});
const tableUser = recentUsers.map((u) => ({
  id: u.id,
  username: u.username,
  fullName: u.fullName,
  role: u.role,
  qrUrl: u.qrUrl ?? "pendiente",
  image: u.avatarUrl,
}));

const tableArticles = totalArticles.map((a) => ({
  id: a.id,
  title: a.title,
  description: a.description,
  category: a.category,
  urgency: a.isUrgent,
}));

---

<Layout title="Admin Dashboard | UK 2026">
  <main class="max-w-5xl mx-auto px-6 py-12 pb-32 bg-white">
    <header class="mb-10 flex justify-between items-end">
      <div>
        <h1 class="text-4xl font-black text-slate-900 tracking-tight">
          Admin Console
        </h1>
        <p class="text-slate-500 mt-2 font-medium">
          Gestiona alumnos, QRs y cronograma del viaje.
        </p>
      </div>
      <div class="text-right">
        <span
          class="text-[10px] font-black uppercase tracking-widest text-indigo-600 bg-indigo-50 px-4 py-2 rounded-full"
        >
          Estás en modo Dios ✨
        </span>
      </div>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
      <div
        class="bg-slate-50 p-8 rounded-[2.5rem] border border-slate-100 shadow-sm"
      >
        <a href="#usuarios">
          <p
            class="text-[10px] font-black uppercase text-slate-400 tracking-widest mb-1"
          >
            Alumnos
          </p>

          <h2 class="text-4xl font-black text-slate-900">
            {recentUsers.length}
          </h2>
        </a>
      </div>
      <div
        class="bg-slate-50 p-8 rounded-[2.5rem] border border-slate-100 shadow-sm"
      >
        <a href="#eventos">
          <p
            class="text-[10px] font-black uppercase text-slate-400 tracking-widest mb-1"
          >
            Eventos UK
          </p>
          <h2 class="text-4xl font-black text-slate-900">
            {totalEvents.length}
          </h2>
        </a>
      </div>
      <div
        class="bg-slate-50 p-8 rounded-[2.5rem] border border-slate-100 shadow-sm"
      >
        <a href="#articulos">
          <p
            class="text-[10px] font-black uppercase text-slate-400 tracking-widest mb-1"
          >
            Wiki Publicadas
          </p>
          <h2 class="text-4xl font-black text-slate-900">
            {totalArticles.length}
          </h2>
        </a>
      </div>
    </div>

    <section class="mb-12">
      <h3
        class="text-xs font-black uppercase text-slate-400 ml-4 mb-6 tracking-widest"
      >
        Acciones Rápidas
      </h3>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <a
          href="/admin/usuarios/nuevo"
          class="p-6 bg-white border-2 border-dashed border-slate-200 rounded-[2rem] flex flex-col items-center justify-center gap-3 hover:border-indigo-400 hover:bg-indigo-50 transition-all group"
        >
          <span class="text-2xl group-hover:scale-110 transition-transform"
            >👤</span
          >
          <span class="text-[10px] font-black uppercase text-slate-600"
            >Nuevo Usuario</span
          >
        </a>
        <a
          href="/admin/itinerario/nuevo"
          class="p-6 bg-white border-2 border-dashed border-slate-200 rounded-[2rem] flex flex-col items-center justify-center gap-3 hover:border-emerald-400 hover:bg-emerald-50 transition-all group"
        >
          <span class="text-2xl group-hover:scale-110 transition-transform"
            >📅</span
          >
          <span class="text-[10px] font-black uppercase text-slate-600"
            >Crear Evento</span
          >
        </a>
        <a
          href="/admin/articulos/nuevo"
          class="p-6 bg-white border-2 border-dashed border-slate-200 rounded-[2rem] flex flex-col items-center justify-center gap-3 hover:border-amber-400 hover:bg-amber-50 transition-all group"
        >
          <span class="text-2xl group-hover:scale-110 transition-transform"
            >🔔</span
          >
          <span class="text-[10px] font-black uppercase text-slate-600"
            >Wiki</span
          >
        </a>
        <button
          onclick="window.print()"
          class="p-6 bg-white border-2 border-dashed border-slate-200 rounded-[2rem] flex flex-col items-center justify-center gap-3 hover:border-slate-400 hover:bg-slate-50 transition-all group"
        >
          <span class="text-2xl group-hover:scale-110 transition-transform"
            >🖨️</span
          >
          <span class="text-[10px] font-black uppercase text-slate-600"
            >Imprimir Reporte</span
          >
        </button>
      </div>
    </section>

    <section
      class="bg-white rounded-[2.5rem] border border-slate-100 shadow-sm overflow-hidden"
    >
      <div id="usuarios">
        <UserAdminTable client:load initialUsers={tableUser} />|
      </div>
      <div id="eventos">
        <EventAdminTable client:load initialEvents={totalEvents} />
      </div>
      <div id="articulos">
        <ArticlesAdminTable client:load initialArticles={totalArticles} />
      </div>
    </section>
    
  </main>
</Layout>
