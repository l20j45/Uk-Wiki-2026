---
import Layout from "../../layouts/Layout.astro";
// Aquí podrías listar todos los posts de Turso para editarlos o borrarlos
---

<Layout title="Panel de Control">
  <div class="max-w-4xl mx-auto px-6 py-12">
    <div class="flex justify-between items-center mb-10">
      <h1 class="text-3xl font-black">Gestión de Contenido</h1>
      <a
        href="/admin/nuevo"
        class="bg-indigo-600 text-white px-6 py-3 rounded-full font-bold shadow-lg hover:scale-105 transition-transform"
      >
        + Nueva Entrada
      </a>
    </div>

    <div class="grid gap-4">
      <div
        class="bg-white p-6 rounded-3xl border border-slate-100 flex justify-between items-center"
      >
        <div>
          <h3 class="font-bold">Protocolo NHS</h3>
          <p class="text-xs text-slate-400">Importancia: 1</p>
        </div>
        <div class="flex gap-2">
          <button class="text-slate-400 hover:text-indigo-600">Editar</button>
          <button class="text-rose-400">Borrar</button>
        </div>
      </div>
    </div>
  </div>
    <main class="max-w-4xl mx-auto px-6 py-12">
    <div class="flex justify-between items-center mb-10">
      <h1 class="text-3xl font-black">Gestión de Contenido</h1>
      <a
        href="/admin/itinerario/nuevo"
        class="bg-indigo-600 text-white px-6 py-3 rounded-full font-bold shadow-lg hover:scale-105 transition-transform"
      >
        + Nueva Entrada
      </a>
    </div>

    <div class="grid gap-4">
      <div
        class="bg-white p-6 rounded-3xl border border-slate-100 flex justify-between items-center"
      >
        <div>
          <h3 class="font-bold">Protocolo NHS</h3>
          <p class="text-xs text-slate-400">Importancia: 1</p>
        </div>
        <div class="flex gap-2">
          <button class="text-slate-400 hover:text-indigo-600">Editar</button>
          <button class="text-rose-400">Borrar</button>
        </div>
      </div>
    </div>
  </main>


</Layout>
