---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Mensaje Enviado">
  <main class="min-h-[60vh] flex flex-col items-center justify-center text-center px-6">
    <div class="text-6xl mb-6">✅</div>
    <h1 class="text-3xl font-black text-slate-900">Mensaje Recibido</h1>
    <p class="text-slate-500 mt-2 max-w-xs">Mantén la calma, un coordinador se pondrá en contacto contigo en breve.</p>
    <a href="/" class="mt-8 text-indigo-600 font-bold underline">Volver al inicio</a>
  </main>
</Layout>