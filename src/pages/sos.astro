---
import Layout from "../layouts/Layout.astro";
---

<Layout title="EMERGENCIA - S.O.S.">
  <main class="max-w-md mx-auto p-6 pt-10 text-center">
    <div class="bg-red-50 border-2 border-red-200 rounded-3xl p-8 mb-6">
      <h1 class="text-3xl font-black text-red-600 mb-2">Centro de Ayuda</h1>
      <p class="text-slate-600 text-sm">
        Si estás perdido o tienes una emergencia, usa los recursos de abajo.
      </p>
    </div>

    <section class="bg-white border shadow-sm rounded-2xl p-6 mb-4 text-left">
      <h2
        class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-2"
      >
        📍 Dirección del Campus
      </h2>
      <p class="text-lg font-bold text-slate-800">
        University of Hertfordshire
      </p>
      <p class="text-slate-600">De Havilland Campus, Hatfield, AL10 9EU, UK</p>
      <button
        onclick="navigator.clipboard.writeText('De Havilland Campus, Hatfield, AL10 9EU')"
        class="mt-3 text-xs text-indigo-600 font-bold underline"
      >
        Copiar dirección
      </button>
    </section>

    <div class="grid gap-3">
      <a
        href="tel:+523312695364"
        class="flex items-center justify-between p-5 bg-indigo-600 text-white rounded-2xl font-bold shadow-lg"
      >
        <span>Llamar Dr. Olivera</span>
        <span class="bg-white/20 p-2 rounded-lg text-sm">📞 Llamar</span>
      </a>

      <a
        href="tel:+523331716277"
        class="flex items-center justify-between p-5 bg-indigo-600 text-white rounded-2xl font-bold shadow-lg"
      >
        <span>Llamar Dr. Soto</span>
        <span class="bg-white/20 p-2 rounded-lg text-sm">📞 Llamar</span>
      </a>

      <a
        href="tel:999"
        class="flex items-center justify-between p-5 bg-slate-900 text-white rounded-2xl font-bold"
      >
        <span>Emergencias UK (999)</span>
        <span class="text-red-400 font-mono italic">POLICE/AMBULANCE</span>
      </a>
    </div>

    <div class="mt-8 p-4 border border-dashed border-slate-300 rounded-2xl">
      <p class="text-xs text-slate-500 mb-2 font-bold">
        🇲🇽 EMBAJADA DE MÉXICO EN LONDRES
      </p>
      <p class="text-sm text-slate-700">16 St. George St, London, W1S 1FD</p>
      <p class="text-sm font-bold text-indigo-600 mt-1">+44 20 7499 8586</p>
    </div>
    <form
      name="contacto-emergencia"
      method="POST"
      data-netlify="true"
      action="/gracias"
      class="space-y-4 border border-slate-200 rounded-2xl p-6 shadow-sm mt-5"
    >
      <input type="hidden" name="form-name" value="contacto-emergencia" />

      <div>
        <label
          class="block text-xs font-bold uppercase text-slate-400 mb-2 ml-1"
          >Tu Nombre</label
        >
        <input
          type="text"
          name="name"
          required
          class="w-full p-4 bg-slate-50 border-none rounded-2xl focus:ring-2 ring-rose-500 outline-none"
          placeholder="Ej. Juan Pérez"
        />
      </div>

      <div>
        <label
          class="block text-xs font-bold uppercase text-slate-400 mb-2 ml-1"
          >Ubicación Actual</label
        >
        <input
          type="text"
          name="location"
          required
          class="w-full p-4 bg-slate-50 border-none rounded-2xl focus:ring-2 ring-rose-500 outline-none"
          placeholder="Ej. Estación Piccadilly Circus"
        />
      </div>

      <div>
        <label
          class="block text-xs font-bold uppercase text-slate-400 mb-2 ml-1"
          >Mensaje / Emergencia</label
        >
        <textarea
          name="message"
          required
          rows="4"
          class="w-full p-4 bg-slate-50 border-none rounded-2xl focus:ring-2 ring-rose-500 outline-none resize-none"
          placeholder="Describe brevemente la situación..."></textarea>
      </div>

      <button
        type="submit"
        class="w-full bg-rose-600 text-white font-bold py-4 rounded-2xl hover:bg-rose-700 transition-all shadow-lg shadow-rose-100 uppercase tracking-widest text-sm"
      >
        Enviar Alerta SOS
      </button>
    </form>
  </main>
</Layout>
